    "db:seed": "tsx scripts/seed.ts",
    "test:smoke": "node --import tsx scripts/smoke-test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.10.1",
    "@stellar/mpp": "^0.4.0",
